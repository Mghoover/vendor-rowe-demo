---
import InfoGrid from "../components/common/InfoGrid.astro";
import SectionHeader from "../components/common/SectionHeader.astro";
import { team } from "../content/team";

const { content } = Astro.props;
---
<section class="content-section">
  <div class="shell split-layout story-layout">
    <div>
      <SectionHeader eyebrow={content.eyebrow} title={content.title} description={content.description} />
      <p class="story-secondary">{content.secondary}</p>
      <InfoGrid items={content.stats} columns={3} />
    </div>
    <div class="story-founder-card">
      <img src={team[0].image} alt={team[0].name} loading="lazy" />
      <div class="story-founder-copy">
        <p class="card-kicker">Founder Perspective</p>
        <h3>{team[0].name}</h3>
        <p class="card-meta">{team[0].role}</p>
        <p>{team[0].bio}</p>
      </div>
    </div>
  </div>
</section>
